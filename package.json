{
  "name": "honeygui-visual-designer",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "1.6.12",
  "license": "MIT",
  "l10n": "./l10n",
  "repository": {
    "type": "git",
    "url": "https://github.com/realmcu/HoneyGUI.git"
  },
  "homepage": "https://github.com/realmcu/HoneyGUI",
  "bugs": {
    "url": "https://github.com/realmcu/HoneyGUI/issues"
  },
  "publisher": "honeygui-visual-designer",
  "icon": "resources/HoneyGUI-LOGO.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Visualization",
    "Other",
    "Programming Languages"
  ],
  "keywords": [
    "HoneyGUI",
    "UI Design",
    "Visual Designer",
    "Embedded UI"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/src/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "hml",
        "aliases": [
          "HML",
          "hml"
        ],
        "extensions": [
          ".hml"
        ],
        "configuration": "./hml.language-configuration.json"
      }
    ],
    "customEditors": [
      {
        "viewType": "honeygui.hmlEditor",
        "displayName": "HoneyGUI Design View",
        "selector": [
          {
            "filenamePattern": "*.hml"
          }
        ],
        "priority": "default"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "honeygui-explorer",
          "title": "HoneyGUI Visual Designer",
          "icon": "resources/HoneyGUI-LOGO.svg",
          "priority": 100
        }
      ]
    },
    "views": {
      "honeygui-explorer": [
        {
          "id": "honeygui.welcome",
          "name": "WELCOME",
          "icon": "$(home)"
        },
        {
          "id": "honeygui.environment",
          "name": "ENVIRONMENT",
          "icon": "$(checklist)"
        },
        {
          "id": "honeygui.quick",
          "name": "QUICK",
          "icon": "$(play)"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "honeygui.welcome",
        "contents": "[$(add) New Project](command:honeygui.newProject)\n[$(file-add) New Design](command:honeygui.createNewHmlInWorkspace)\n[$(folder-opened) Open Project](command:honeygui.openProject)\n[$(tools) Resource Conversion Tools](command:honeygui.tools)\n\nCollaboration:\n[$(broadcast) Start Host](command:honeygui.collaboration.startHost)\n[$(plug) Join Session](command:honeygui.collaboration.joinSession)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "honeygui.openInTextEditor",
          "when": "resourceExtname == .hml",
          "group": "1_open@1"
        },
        {
          "command": "honeygui.openInDesigner",
          "when": "resourceExtname == .hml",
          "group": "1_open@2"
        }
      ],
      "view/title": [
        {
          "command": "honeygui.collaboration.startHost",
          "when": "view == honeygui.welcome",
          "group": "navigation@2"
        },
        {
          "command": "honeygui.collaboration.joinSession",
          "when": "view == honeygui.welcome",
          "group": "navigation@2"
        },
        {
          "command": "honeygui.collaboration.stop",
          "when": "view == honeygui.welcome",
          "group": "navigation@2"
        },
        {
          "command": "honeygui.environment.refresh",
          "when": "view == honeygui.environment",
          "group": "navigation"
        }
      ]
    },
    "commands": [
      {
        "command": "honeygui.createNewHmlInWorkspace",
        "title": "%command.createNewHml%",
        "category": "HoneyGUI"
      },
      {
        "command": "honeygui.tools",
        "title": "%command.tools%",
        "category": "HoneyGUI"
      },
      {
        "command": "honeygui.openInTextEditor",
        "title": "%command.openInTextEditor%",
        "category": "HoneyGUI"
      },
      {
        "command": "honeygui.openInDesigner",
        "title": "%command.openInDesigner%",
        "category": "HoneyGUI"
      },
      {
        "command": "honeygui.newProject",
        "title": "%command.newProject%",
        "category": "HoneyGUI"
      },
      {
        "command": "honeygui.openProject",
        "title": "%command.openProject%",
        "category": "HoneyGUI"
      },
      {
        "command": "honeygui.codegen",
        "title": "%command.codegen%",
        "category": "HoneyGUI"
      },
      {
        "command": "honeygui.preview",
        "title": "%command.preview%",
        "category": "HoneyGUI",
        "icon": "$(eye)"
      },
      {
        "command": "honeygui.simulation",
        "title": "%command.simulation%",
        "category": "HoneyGUI",
        "icon": "$(rocket)"
      },
      {
        "command": "honeygui.simulation.stop",
        "title": "%command.simulationStop%",
        "category": "HoneyGUI",
        "icon": "$(debug-stop)"
      },
      {
        "command": "honeygui.collaboration.startHost",
        "title": "%command.startHost%",
        "category": "HoneyGUI",
        "icon": "$(broadcast)"
      },
      {
        "command": "honeygui.collaboration.joinSession",
        "title": "%command.joinSession%",
        "category": "HoneyGUI",
        "icon": "$(plug)"
      },
      {
        "command": "honeygui.collaboration.stop",
        "title": "%command.stopCollaboration%",
        "category": "HoneyGUI",
        "icon": "$(debug-stop)"
      },
      {
        "command": "honeygui.environment.refresh",
        "title": "%command.refreshEnvironment%",
        "category": "HoneyGUI",
        "icon": "$(refresh)"
      }
    ],
    "keybindings": [
      {
        "command": "honeygui.simulation.stop",
        "key": "ctrl+shift+f5",
        "mac": "cmd+shift+f5",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "HoneyGUI",
      "properties": {
        "honeygui.codegen.language": {
          "type": "string",
          "default": "cpp",
          "enum": [
            "cpp",
            "c"
          ],
          "description": "代码生成语言"
        },
        "honeygui.codegen.outputDir": {
          "type": "string",
          "default": "src/ui",
          "description": "代码输出目录"
        },
        "honeygui.hml.outputDir": {
          "type": "string",
          "default": "ui",
          "description": "HML输出目录"
        },
        "honeygui.preview.runnerPath": {
          "type": "string",
          "default": "",
          "description": "预览Runner路径"
        },
        "honeygui.preview.timeoutMs": {
          "type": "number",
          "default": 10000,
          "description": "预览超时时间（毫秒）"
        },
        "honeygui.ui.gridSize": {
          "type": "number",
          "default": 8,
          "description": "网格大小"
        },
        "honeygui.ui.snapToGrid": {
          "type": "boolean",
          "default": true,
          "description": "启用网格吸附"
        },
        "honeygui.codeGeneration.outputPath": {
          "type": "string",
          "default": "src",
          "description": "代码生成输出路径"
        },
        "honeygui.codeGeneration.enableDebugInfo": {
          "type": "boolean",
          "default": true,
          "description": "启用调试信息"
        },
        "honeygui.preview.autoReload": {
          "type": "boolean",
          "default": true,
          "description": "启用自动重载"
        }
      }
    }
  },
  "scripts": {
    "test": "npm run test:templates",
    "test:templates": "npm run compile && node ./out/test/templates/run-templates-tests.js",
    "check:deps": "node scripts/check-dependencies.js",
    "update:deps": "node scripts/update-vscodeignore.js",
    "prepackage": "npm run check:deps",
    "test:video-formats": "npx ts-node scripts/test-three-formats.ts",
    "test:video-formats:quick": "node test-formats-quick.js",
    "vscode:prepublish": "npm run update:deps && npm run compile && npm run build:webview",
    "compile": "npm run clean:src && tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint . --ext .ts,.tsx",
    "build:webview": "webpack --mode production",
    "build:webview:dev": "webpack --mode development",
    "watch:webview": "webpack --mode development --watch",
    "serve:webview": "webpack serve --mode development",
    "clean": "node scripts/clear-cache.js",
    "clean:src": "node scripts/clean-js.js",
    "clean:all": "npm run clean && rimraf node_modules && npm install",
    "rebuild": "npm run clean && npm run compile && npm run build:webview",
    "prepare:lib": "./scripts/prepare-lib-sim.sh",
    "package": "npm run compile && npm run build:webview && vsce package"
  },
  "devDependencies": {
    "@types/bmp-js": "^0.1.2",
    "@types/ini": "^4.1.1",
    "@types/jpeg-js": "^0.3.0",
    "@types/node": "^20.19.25",
    "@types/opentype.js": "^1.3.8",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.2.4",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.181.0",
    "@types/vscode": "^1.80.0",
    "@types/webpack": "^5.28.5",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^5.1.1",
    "@vscode/vsce": "^3.7.1",
    "baseline-browser-mapping": "^2.9.14",
    "css-loader": "^7.1.2",
    "esbuild": "^0.27.0",
    "eslint": "^8.56.0",
    "eslint-plugin-import": "^2.32.0",
    "glob": "^11.0.3",
    "html-webpack-plugin": "^5.6.4",
    "mini-css-extract-plugin": "^2.9.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "style-loader": "^4.0.0",
    "terser-webpack-plugin": "^5.3.14",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0",
    "vite": "^7.2.2",
    "webpack": "^5.102.1",
    "webpack-bundle-analyzer": "^4.10.2",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2"
  },
  "dependencies": {
    "bmp-js": "^0.1.0",
    "chokidar": "^3.6.0",
    "fabric": "^7.1.0",
    "fast-xml-parser": "^4.3.2",
    "html2canvas": "^1.4.1",
    "ini": "^4.1.3",
    "jpeg-js": "^0.4.4",
    "lucide-react": "^0.553.0",
    "mp4box": "^2.3.0",
    "opentype.js": "^1.3.4",
    "pngjs": "^7.0.0",
    "three": "^0.181.2",
    "ws": "^8.18.3",
    "xml-js": "^1.6.11",
    "zustand": "^5.0.8"
  }
}
