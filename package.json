{
  "name": "honeygui-visual-designer",
  "displayName": "HoneyGUI Visual Designer",
  "description": "VS Code 插件，提供 HoneyGUI 可视化界面设计、HML 编辑、C/C++ 代码生成与实时预览功能。",
  "version": "1.1.5",
  "repository": {
    "type": "git",
    "url": "https://gitee.com/example/honey-gui-plugin.git"
  },
  "publisher": "honeygui",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Visualization",
    "Other",
    "Programming Languages"
  ],
  "keywords": [
    "HoneyGUI",
    "UI Design",
    "Visual Designer",
    "Embedded UI"
  ],
  "activationEvents": [
    "onCommand:honeygui.newProject",
    "onCommand:honeygui.openDesigner",
    "onCommand:honeygui.codegen",
    "onCommand:honeygui.preview",
    "onCommand:honeygui.openResourceManager",
    "onCommand:honeygui.openDocs",
    "onCommand:honeygui.migrateXmlToHml",
    "onView:honeygui.welcome",
    "onView:honeygui.quick",
    "onWorkspaceContains:**/*.hml"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "hml",
        "aliases": ["HML", "hml"],
        "extensions": [".hml"],
        "configuration": "./hml.language-configuration.json"
      }
    ],
    "customEditors": [
      {
        "viewType": "honeygui.hmlEditor",
        "displayName": "HoneyGUI Design View",
        "selector": [
          {
            "filenamePattern": "*.hml"
          }
        ],
        "priority": "option"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "honeygui-explorer",
          "title": "HoneyGUI Visual Designer",
          "icon": "resources/honeygui-icon.svg",
          "priority": 100
        }
      ]
    },
    "views": {
      "honeygui-explorer": [
        {
          "id": "honeygui.welcome",
          "name": "WELCOME",
          "icon": "$(home)"
        },
        {
          "id": "honeygui.quick",
          "name": "QUICK",
          "icon": "$(play)"
        }
      ]
    },
    "menus": {
      "explorer/context": [
        {
          "command": "honeygui.openInTextEditor",
          "when": "resourceExtname == .hml",
          "group": "1_open@1"
        },
        {
          "command": "honeygui.openInDesigner",
          "when": "resourceExtname == .hml",
          "group": "1_open@2"
        },
        {
          "command": "honeygui.createNewHmlFile",
          "when": "explorerResourceIsFolder",
          "group": "2_new@1"
        }
      ],
      "view/title": [
        {
          "command": "honeygui.switchView",
          "when": "view == honeygui.welcome",
          "group": "navigation@1"
        },
        {
          "command": "honeygui.switchView",
          "when": "view == honeygui.quick",
          "group": "navigation@1"
        }
      ]
    },
    "commands": [
      {
        "command": "honeygui.switchView",
        "title": "Switch View",
        "icon": "$(swap-horizontal)"
      },
      {
        "command": "honeygui.createNewHmlInWorkspace",
        "title": "HoneyGUI: Create New HML File",
        "category": "HoneyGUI"
      },
      {
        "command": "honeygui.openInTextEditor",
        "title": "Open with Text Editor",
        "category": "HoneyGUI"
      },
      {
        "command": "honeygui.openInDesigner",
        "title": "Open with HoneyGUI Designer",
        "category": "HoneyGUI"
      },
      {
        "command": "honeygui.createNewHmlFile",
        "title": "Create New Design File",
        "category": "HoneyGUI"
      },
      {
        "command": "honeygui.newProject",
        "title": "HoneyGUI: New Project",
        "category": "HoneyGUI"
      },
      {
        "command": "honeygui.openDesigner",
        "title": "HoneyGUI: Open Designer",
        "category": "HoneyGUI"
      },
      {
        "command": "honeygui.codegen",
        "title": "HoneyGUI: Generate Code",
        "category": "HoneyGUI"
      },
      {
        "command": "honeygui.preview",
        "title": "HoneyGUI: Preview",
        "category": "HoneyGUI"
      },
      {
        "command": "honeygui.openResourceManager",
        "title": "HoneyGUI: Open Resource Manager",
        "category": "HoneyGUI"
      },
      {
        "command": "honeygui.openDocs",
        "title": "HoneyGUI: Open Docs",
        "category": "HoneyGUI"
      },
      {
        "command": "honeygui.migrateXmlToHml",
        "title": "HoneyGUI: Migrate XML to HML",
        "category": "HoneyGUI"
      },
      {
        "command": "honeygui.openProject",
        "title": "Open Project",
        "category": "HoneyGUI"
      },
      {
        "command": "honeygui.openRecent",
        "title": "Open Recent",
        "category": "HoneyGUI"
      },
      {
        "command": "honeygui.showCreateProjectForm",
        "title": "Create Project",
        "category": "HoneyGUI"
      },
      {
        "command": "honeygui.openSettings",
        "title": "Settings",
        "category": "HoneyGUI",
        "icon": "$(gear)"
      },
      {
        "command": "honeygui.startProject",
        "title": "Start",
        "category": "HoneyGUI",
        "icon": "$(play)"
      },
      {
        "command": "honeygui.stopProject",
        "title": "Stop",
        "category": "HoneyGUI",
        "icon": "$(stop)"
      },
      {
        "command": "honeygui.restartProject",
        "title": "Restart",
        "category": "HoneyGUI",
        "icon": "$(refresh)"
      },
      {
        "command": "honeygui.toggleEditor",
        "title": "Toggle Editor Mode",
        "category": "HoneyGUI"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "HoneyGUI",
      "properties": {
        "honeygui.codegen.language": {
          "type": "string",
          "default": "cpp",
          "enum": [
            "cpp",
            "c"
          ],
          "description": "代码生成语言"
        },
        "honeygui.codegen.outputDir": {
          "type": "string",
          "default": "src/ui",
          "description": "代码输出目录"
        },
        "honeygui.hml.outputDir": {
          "type": "string",
          "default": "ui",
          "description": "HML输出目录"
        },
        "honeygui.preview.runnerPath": {
          "type": "string",
          "default": "",
          "description": "预览Runner路径"
        },
        "honeygui.preview.autoDownload": {
          "type": "boolean",
          "default": false,
          "description": "自动下载Runner（开发阶段：默认禁用，避免网络访问失败）"
        },
        "honeygui.preview.timeoutMs": {
          "type": "number",
          "default": 10000,
          "description": "预览超时时间（毫秒）"
        },
        "honeygui.ui.gridSize": {
          "type": "number",
          "default": 8,
          "description": "网格大小"
        },
        "honeygui.ui.snapToGrid": {
          "type": "boolean",
          "default": true,
          "description": "启用网格吸附"
        },
        "honeygui.telemetry.enabled": {
          "type": "boolean",
          "default": true,
          "description": "启用遥测"
        },
        "honeygui.codeGeneration.outputPath": {
          "type": "string",
          "default": "src",
          "description": "代码生成输出路径"
        },
        "honeygui.codeGeneration.cppVersion": {
          "type": "string",
          "default": "c++17",
          "description": "C++版本"
        },
        "honeygui.codeGeneration.enableDebugInfo": {
          "type": "boolean",
          "default": true,
          "description": "启用调试信息"
        },
        "honeygui.preview.autoReload": {
          "type": "boolean",
          "default": true,
          "description": "启用自动重载"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run build:webview",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint . --ext .ts,.tsx",
    "build:webview": "webpack --mode production",
    "build:webview:dev": "webpack --mode development",
    "watch:webview": "webpack --mode development --watch",
    "serve:webview": "webpack serve --mode development"
  },
  "devDependencies": {
    "esbuild": "^0.27.0",
    "@types/node": "^20.19.25",
    "@types/react": "^19.2.4",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.80.0",
    "@types/webpack": "^5.28.5",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^5.1.1",
    "css-loader": "^7.1.2",
    "eslint": "^8.56.0",
    "eslint-plugin-import": "^2.32.0",
    "glob": "^11.0.3",
    "html-webpack-plugin": "^5.6.4",
    "mini-css-extract-plugin": "^2.9.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "style-loader": "^4.0.0",
    "terser-webpack-plugin": "^5.3.14",
    "ts-loader": "^9.5.4",
    "typescript": "^5.3.0",
    "vite": "^7.2.2",
    "webpack": "^5.102.1",
    "webpack-bundle-analyzer": "^4.10.2",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "fast-xml-parser": "^4.3.2",
    "lucide-react": "^0.553.0",
    "xml-js": "^1.6.11",
    "zustand": "^5.0.8"
  }
}
