                "content": [
                  {
                    "Text": "An error occurred processing the tool: \nno occurrences of \"    /**\n     * 生成 ROMFS 文件系统\n     */\n    protected async generateRomfs(): Promise<void> {\n        const assetsDir = path.join(this.buildDir, 'assets');\n        const romfsOutput = path.join(this.buildDir, RomfsConfig.getFileName());\n        const romfsBinOutput = path.join(this.buildDir, 'app_romfs.bin');\n        // 使用内置的 mkromfs 脚本\n        const mkromfsScript = path.join(this.libSimPath, 'tool', 'mkromfs', 'mkromfs_for_honeygui.py');\n\n        if (!fs.existsSync(mkromfsScript)) {\n            throw new Error(`mkromfs 脚本不存在: ${mkromfsScript}`);\n        }\n\n        if (!fs.existsSync(assetsDir)) {\n            this.logger.log('assets 目录不存在，跳过 ROMFS 生成');\n            return;\n        }\n\n        this.logger.log('生成 ROMFS...');\n\n        const baseAddr = this.projectConfig.romfsBaseAddr || DEFAULT_ROMFS_BASE_ADDR;\n        const baseAddrHex = `0x${baseAddr.toString(16).toUpperCase()}`;\n\n        const args = [\n            mkromfsScript,\n            '-i', assetsDir,\n            '-o', romfsOutput,\n            '-a', baseAddrHex\n        ];\n\n        try {\n            const result = await this.executeCommand('python3', args, this.buildDir);\n            if (result.code !== 0) {\n                throw new Error(`mkromfs 执行失败: ${result.stderr}`);\n            }\n            this.logger.log('ROMFS 生成完成');\n        } catch (error) {\n            throw new Error(`生成 ROMFS 失败: ${error}`);\n        }\n    }\" were found"
                  }
                ],
                "status": "Error"
              }
            ]
          }
        },
