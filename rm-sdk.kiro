    "github": [
      {
        "ToolSpecification": {
          "name": "create_pull_request",
          "description": "Create a new pull request in a GitHub repository",
          "input_schema": {
            "json": {
              "properties": {
                "title": {
                  "type": "string",
                  "description": "Pull request title"
                },
                "head": {
                  "type": "string",
                  "description": "The name of the branch where your changes are implemented"
                },
                "draft": {
                  "type": "boolean",
                  "description": "Whether to create the pull request as a draft"
                },
                "base": {
                  "type": "string",
                  "description": "The name of the branch you want the changes pulled into"
                },
                "owner": {
                  "description": "Repository owner (username or organization)",
                  "type": "string"
                },
                "repo": {
                  "type": "string",
                  "description": "Repository name"
                },
                "body": {
                  "type": "string",
                  "description": "Pull request body/description"
                },
                "maintainer_can_modify": {
                  "description": "Whether maintainers can modify the pull request",
                  "type": "boolean"
                }
              },
              "type": "object",
              "required": [
                "owner",
                "repo",
                "title",
                "head",
                "base"
              ],
              "additionalProperties": false,
              "$schema": "http://json-schema.org/draft-07/schema#"
            }
          }
        }
      },
      {
        "ToolSpecification": {
          "name": "create_pull_request_review",
          "description": "Create a review on a pull request",
          "input_schema": {
            "json": {
              "properties": {
                "body": {
                  "type": "string",
                  "description": "The body text of the review"
                },
                "event": {
                  "enum": [
                    "APPROVE",
                    "REQUEST_CHANGES",
                    "COMMENT"
                  ],
                  "description": "The review action to perform",
                  "type": "string"
                },
                "comments": {
                  "type": "array",
                  "items": {
                    "anyOf": [
                      {
                        "required": [
                          "path",
                          "position",
                          "body"
                        ],
                        "properties": {
                          "body": {
                            "type": "string",
                            "description": "Text of the review comment"
                          },
                          "position": {
                            "type": "number",
                            "description": "The position in the diff where you want to add a review comment"
                          },
                          "path": {
                            "description": "The relative path to the file being commented on",
                            "type": "string"
                          }
                        },
                        "type": "object",
                        "additionalProperties": false
                      },
                      {
                        "properties": {
                          "path": {
                            "type": "string",
                            "description": "The relative path to the file being commented on"
                          },
                          "line": {
                            "description": "The line number in the file where you want to add a review comment",
                            "type": "number"
                          },
                          "body": {
                            "type": "string",
                            "description": "Text of the review comment"
                          }
                        },
                        "additionalProperties": false,
                        "required": [
                          "path",
                          "line",
                          "body"
                        ],
                        "type": "object"
                      }
                    ]
                  },
                  "description": "Comments to post as part of the review (specify either position or line, not both)"
                },
                "owner": {
                  "description": "Repository owner (username or organization)",
                  "type": "string"
                },
                "pull_number": {
                  "description": "Pull request number",
                  "type": "number"
                },
                "commit_id": {
                  "type": "string",
                  "description": "The SHA of the commit that needs a review"
                },
                "repo": {
                  "type": "string",
                  "description": "Repository name"
                }
              },
              "type": "object",
              "$schema": "http://json-schema.org/draft-07/schema#",
              "required": [
                "owner",
                "repo",
                "pull_number",
                "body",
                "event"
              ],
              "additionalProperties": false
            }
          }
        }
