                    "Text": "import os\nimport sys\nimport menu_config\nfrom SCons.Script import *\n\n# 固定到插件内置的 lib/sim\nPROJECT_ROOT = '/home/howie_wang/workspace/honeygui-design/lib/sim'\nTOOL_ROOT = os.path.join(PROJECT_ROOT, 'tool/scons-tool')\n\nsys.path.append(TOOL_ROOT)\nfrom building import *\n\nTARGET = 'gui.exe' if sys.platform == 'win32' else 'gui'\n\n# 构建环境参数\nenv_params = {\n    'CC': menu_config.CC,\n    'CFLAGS': menu_config.CFLAGS + ' -DDRV_LCD_WIDTH=410 -DDRV_LCD_HEIGHT=502 -DDRV_LCD_CORNER_RADIUS=0 -I/home/howie_wang/workspace/honeygui-design/lib/sim/include -I/home/howie_wang/workspace/honeygui-design/lib/sim/SDL2-2.26.0-STATIC/include -I/home/howie_wang/workspace/honeygui-design/lib/sim/SDL2-2.26.0-STATIC/include/SDL2',\n    'CXX': menu_config.CXX,\n    'CXXFLAGS': menu_config.CXXFLAGS,\n    'LINKFLAGS': menu_config.LFLAGS + ' -L/home/howie_wang/workspace/honeygui-design/lib/sim/linux -lgui -L/home/howie_wang/workspace/honeygui-design/lib/sim/SDL2-2.26.0-STATIC/lib -lSDL2main -lSDL2'\n}\n\nif sys.platform == 'win32':\n    env = Environment(tools=['mingw'], **env_params)\nelse:\n    env = Environment(tools=['default'], PROGSUFFIX='', **env_params)\n\n# PC 仿真宏\nenv.Append(CPPDEFINES=['_HONEYGUI_SIMULATOR_'])\n\n# 准备环境（生成 hgconfig.h 等）\nobjs = PrepareBuilding(env, TOOL_ROOT, has_libcpu=False)\n\n# 编译本地仿真端代码（当前目录 SConscript）\nif os.path.exists('SConscript'):\n    objs.extend(SConscript('SConscript'))\n\n# 编译项目 src 代码\nPROJECT_SRC = '/home/howie_wang/NewProject/src'\nif os.path.exists(os.path.join(PROJECT_SRC, 'SConscript')):\n    objs.extend(SConscript(os.path.join(PROJECT_SRC, 'SConscript')))\n\n# 构建目标\nDoBuilding(TARGET, objs)"
