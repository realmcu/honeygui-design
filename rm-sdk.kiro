                "content": [
                  {
                    "Json": {
                      "exit_status": "0",
                      "stdout": "import os\nimport sys\nimport menu_config\nfrom SCons.Script import *\n\n# 固定到插件内置的 lib/sim\nPROJECT_ROOT = 'C:/Users/test/lib/sim'\nTOOL_ROOT = os.path.join(PROJECT_ROOT, 'tool/scons-tool')\n\nsys.path.append(TOOL_ROOT)\nfrom building import *\n\nTARGET = 'gui.exe' if sys.platform == 'win32' else 'gui'\n\n# Windows: 使用内置 SDL2 静态库\nsdl2_inc1 = 'C:/Users/test/lib/sim/SDL2-2.26.0-STATIC/include'\nsdl2_inc2 = 'C:/Users/test/lib/sim/SDL2-2.26.0-STATIC/include/SDL2'\nsdl2_libdir = 'C:/Users/test/lib/sim/SDL2-2.26.0-STATIC/lib'\n\n# 构建环境参数\nenv_params = {\n    'CC': menu_config.CC,\n    'CFLAGS': menu_config.CFLAGS + ' -DDRV_LCD_WIDTH=480 -DDRV_LCD_HEIGHT=272 -DDRV_LCD_CORNER_RADIUS=0 -IC:/Users/test/lib/sim/include -I' + sdl2_inc1 + ' -I' + sdl2_inc2,\n    'CXX': menu_config.CXX,\n    'CXXFLAGS': menu_config.CXXFLAGS,\n    'LINKFLAGS': menu_config.LFLAGS\n}\n\nif sys.platform == 'win32':\n    env = Environment(tools=['mingw'], **env_params)\nelse:\n    env = Environment(tools=['default'], PROGSUFFIX='', **env_params)\n    env['LINK'] = 'g++'\n\n# PC 仿真宏\nenv.Append(CPPDEFINES=['_HONEYGUI_SIMULATOR_'])\n\n# 头文件与库路径\nenv.AppendUnique(CPPPATH=['C:/Users/test/lib/sim/include', sdl2_inc1, sdl2_inc2])\nenv.AppendUnique(LIBPATH=['C:/Users/test/lib/sim/win32', sdl2_libdir])\n\n# 系统库\nenv.AppendUnique(LIBS=['mingw32', 'gui', 'SDL2main', 'SDL2', 'opengl32', 'gdi32', 'user32', 'winmm', 'imm32', 'ole32', 'oleaut32', 'version', 'uuid', 'advapi32', 'setupapi', 'shell32', 'dinput8', 'm'])\n\n# 准备环境（会自动编译当前目录的 SConscript）\nobjs = PrepareBuilding(env, TOOL_ROOT, has_libcpu=False)\n\n# 编译项目代码\nPROJECT_SRC = 'C:/Users/test/project/src'\nif os.path.exists(os.path.join(PROJECT_SRC, 'SConscript')):",
                      "stderr": ""
                    }
                  }
                ],
                "status": "Success"
              }
            ]
          }
