                "file_text": "# for module compiling\nimport os\nimport sys\n\nfrom building import *\n\ncwd = GetCurrentDir()\ninc = [cwd]\nsrc = Glob('*.c')\n\nobjs = DefineGroup('rtk_gui', src, depend = [''], CPPPATH = inc)\nlist = os.listdir(cwd)\nfor d in list:\n    # 排除 SCons 构建目录和隐藏目录\n    if d in ['build', '.sconsign.dblite'] or d.startswith('.'):\n        continue\n    path = os.path.join(cwd, d)\n    if os.path.isfile(os.path.join(path, 'SConscript')):\n        objs = objs + SConscript(os.path.join(d, 'SConscript'))\n\nReturn('objs')\n",
