{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "outDir": "out",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react",
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "video-converter-ts": ["./node_modules/video-converter-ts/dist/index.d.ts"]
    }
  },
  "include": [
    "src/**/*",
    "test/**/*",
    "tools/video-converter-ts/src/**/*",
    "tools/image-to-jpeg-converter/src/**/*"
  ],
  "exclude": [
    "node_modules",
    ".vscode-test",
    "src/webview",
    "src/HoneyGUI/tool/D2XML"
  ]
}