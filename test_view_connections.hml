<?xml version="1.0" encoding="UTF-8"?>
<hml>
    <meta>
        <project name="ViewConnectionTest" appId="com.test.viewconnection" resolution="480X272" minSdk="API 2: HoneyGUI V1.1.0" pixelMode="ARGB8888" />
        <author name="Test" />
    </meta>
    <view>
        <hg_screen id="screen1" x="0" y="0" width="480" height="272" backgroundColor="#000000" name="mainScreen">
            <hg_view id="view1" x="20" y="20" width="200" height="150" backgroundColor="#FF5722" name="homeView">
                <view_switch event="GUI_EVENT_TOUCH_MOVE_RIGHT" target="settingsView" switch_out_style="STYLE_SLIDE_LEFT" switch_in_style="STYLE_SLIDE_LEFT" />
                <hg_text id="text1" x="50" y="60" width="100" height="30" text="Home" fontSize="16" color="#FFFFFF" />
            </hg_view>
            
            <hg_view id="view2" x="240" y="20" width="200" height="150" backgroundColor="#2196F3" name="settingsView">
                <view_switch event="GUI_EVENT_TOUCH_MOVE_LEFT" target="homeView" switch_out_style="STYLE_SLIDE_RIGHT" switch_in_style="STYLE_SLIDE_RIGHT" />
                <view_switch event="GUI_EVENT_TOUCH_MOVE_DOWN" target="detailView" switch_out_style="STYLE_SLIDE_UP" switch_in_style="STYLE_SLIDE_UP" />
                <hg_text id="text2" x="50" y="60" width="100" height="30" text="Settings" fontSize="16" color="#FFFFFF" />
            </hg_view>
            
            <hg_view id="view3" x="130" y="190" width="200" height="150" backgroundColor="#4CAF50" name="detailView">
                <view_switch event="GUI_EVENT_TOUCH_MOVE_UP" target="settingsView" switch_out_style="STYLE_SLIDE_DOWN" switch_in_style="STYLE_SLIDE_DOWN" />
                <hg_text id="text3" x="50" y="60" width="100" height="30" text="Detail" fontSize="16" color="#FFFFFF" />
            </hg_view>
        </hg_screen>
    </view>
</hml>
