# Artistic Style (astyle) Configuration File
# For TrMap Project C/C++ Code Formatting
# Usage: astyle --options=.astylerc <files>

# Bracket Style
--style=allman

# Indentation
--indent=spaces=4
--indent-switches
--indent-cases
--indent-col1-comments

# Padding
--pad-oper
--pad-comma
--pad-header
--unpad-paren
--align-pointer=name
--align-reference=name

# Formatting
--break-one-line-headers
--add-braces
--convert-tabs
--max-code-length=120
--break-after-logical

# Line endings
--lineend=windows

# File handling
--suffix=none
--preserve-date
--formatted
--verbose
