# ========================================
# HoneyGUI Visual Designer - VSCode Ignore
# ========================================

# 开发配置
.vscode/**
.git/**
.gitignore
.trae/**
.kiro/**
tsconfig.json
webpack.config.js
AGENTS.md

# 源码（编译后的在 out/ 目录）
src/**
!src/designer/templates/**

# TypeScript 相关
*.ts
*.map
# 排除 source map 但保留编译后的 JS
out/**/*.map

# 测试
test/**
test-service-output/**
test-services.js

# 脚本和文档
scripts/**
docs/**
!docs/HML-Spec.md

# Tools - 只保留运行时需要的工具
tools/**
!tools/mpcli_meta_tool_py_v4.0.0.4/**
!tools/mkromfs_for_honeygui.py
# 保留 video-converter-ts 的编译输出
!tools/video-converter-ts/**
tools/video-converter-ts/src/**/*.ts
tools/video-converter-ts/tests/**
tools/video-converter-ts/node_modules/**
# 保留字库工具的 charset（.cst 文件）和常用 CodePage（NLS 文件）
!tools/font-converter/charset/**
# 只保留嵌入式常用 CodePage，完整目录约 9MB，精简后约 1MB
!tools/font-converter/CodePage/CP936
!tools/font-converter/CodePage/CP950
!tools/font-converter/CodePage/CP932
!tools/font-converter/CodePage/CP949
!tools/font-converter/CodePage/CP1250
!tools/font-converter/CodePage/CP1251
!tools/font-converter/CodePage/CP1252
!tools/font-converter/CodePage/CP1253
!tools/font-converter/CodePage/CP1254
!tools/font-converter/CodePage/CP1255
!tools/font-converter/CodePage/CP1256
!tools/font-converter/CodePage/CP1257
!tools/font-converter/CodePage/CP1258
!tools/font-converter/CodePage/CP874
!tools/font-converter/CodePage/CP437

# 其他
azure.png
*.vsix
fail.log

# ========================================
# 模板项目 - 排除编译产物和大文件
# ========================================
template-projects/**/build/**
template-projects/**/node_modules/**
template-projects/**/.vscode/**
template-projects/**/*.exe
template-projects/**/*.o
template-projects/**/*.a

# ========================================
# Node Modules - 只保留 Extension 端运行时依赖
# ========================================
node_modules/**

# Extension 端核心依赖（Webview 依赖已由 webpack 打包）
!node_modules/fast-xml-parser/**
!node_modules/strnum/**
!node_modules/mp4box/**
!node_modules/opentype.js/**
!node_modules/string.prototype.codepointat/**
!node_modules/tiny-inflate/**
!node_modules/ws/**
!node_modules/minimatch/**
!node_modules/@isaacs/**

# 图片转换工具依赖
!node_modules/pngjs/**
!node_modules/jpeg-js/**
!node_modules/bmp-js/**
*.kiro
rm-sdk.kiro
AGENTS.md
