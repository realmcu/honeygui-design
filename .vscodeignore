# ========================================
# HoneyGUI Visual Designer - VSCode Ignore
# ========================================

# 开发配置
.vscode/**
.git/**
.gitignore
.trae/**
.kiro/**
tsconfig.json
webpack.config.js
AGENTS.md

# 源码（编译后的在 out/ 目录）
src/**
!src/designer/templates/**

# TypeScript 相关
*.ts
*.map

# 测试
test/**
test-service-output/**
test-services.js

# 脚本和文档
scripts/**
docs/**
tools/**
!tools/mpcli_meta_tool_py_v4.0.0.4/**

# 其他
azure.png
*.vsix
fail.log

# ========================================
# 模板项目 - 排除编译产物和大文件
# ========================================
template-projects/**/build/**
template-projects/**/node_modules/**
template-projects/**/.vscode/**
template-projects/**/*.exe
template-projects/**/*.o
template-projects/**/*.a

# ========================================
# Node Modules - 只保留运行时依赖
# ========================================
node_modules/**

# 核心依赖 (自动生成，请勿手动修改此部分)
# AUTO-GENERATED-DEPS-START
!node_modules/bmp-js/**
!node_modules/chokidar/**
!node_modules/fast-xml-parser/**
!node_modules/ini/**
!node_modules/jpeg-js/**
!node_modules/mp4box/**
!node_modules/opentype.js/**
!node_modules/pngjs/**
!node_modules/ws/**
!node_modules/xml-js/**
# AUTO-GENERATED-DEPS-END

# chokidar 依赖链
!node_modules/anymatch/**
!node_modules/braces/**
!node_modules/fill-range/**
!node_modules/to-regex-range/**
!node_modules/is-number/**
!node_modules/glob-parent/**
!node_modules/is-glob/**
!node_modules/is-extglob/**
!node_modules/is-binary-path/**
!node_modules/binary-extensions/**
!node_modules/normalize-path/**
!node_modules/readdirp/**
!node_modules/picomatch/**

# fast-xml-parser 依赖
!node_modules/strnum/**

# xml-js 依赖
!node_modules/sax/**
