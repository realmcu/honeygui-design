nd - empty:', !!tabEmpty, 'template:', !!tabTemplate);\\n  426:                     console.log('Form elements found:', {\\n  427:                         folderBtn: !!selectFolderButton,\\n→ 428:                         saveLocation: !!saveLocationInput,\\n  429:                         createBtn: !!createButton,\\n  430:                         appId: !!appIdInput,\\n  431:                         resolution: !!resolutionSelect,\\n\"},{\"line_number\":469,\"context\":\"  466:                     }\\n  467: \\n  468:                     // 绑定表单验证事件\\n→ 469:                     if (saveLocationInput) {\\n  470:                         saveLocationInput.addEventListener('input', function() {\\n  471:                             console.log('Save location input changed');\\n  472:                             validateForm();\\n\"},{\"line_number\":470,\"context\":\"  467: \\n  468:                     // 绑定表单验证事件\\n  469:                     if (saveLocationInput) {\\n→ 470:                         saveLocationInput.addEventListener('input', function() {\\n  471:                             console.log('Save location input changed');\\n  472:                             validateForm();\\n  473:                         });\\n\"},{\"line_number\":529,\"context\":\"  526:                 function validateForm() {\\n  527:                     console.log('Validating form...');\\n  528:                     const projectName = document.getElementById('projectName').value.trim();\\n→ 529:                     const saveLocation = document.getElementById('saveLocation').value.trim();\\n  530:                     const createButton = document.getElementById('createButton');\\n  531: \\n  532:                     console.log('Project name:', projectName, 'Save location:', saveLocation);\\n\"},{\"line_number\":532,\"context\":\"  529:                     const saveLocation = document.getElementById('saveLocation').value.trim();\\n  530:                     const createButton = document.getElementById('createButton');\\n  531: \\n→ 532:                     console.log('Project name:', projectName, 'Save location:', saveLocation);\\n  533: \\n  534:                     // 清除之前的错误消息\\n  535:                     if (projectName || saveLocation) {\\n\"},{\"line_number\":535,\"context\":\"  532:                     console.log('Project name:', projectName, 'Save location:', saveLocation);\\n  533: \\n  534:                     // 清除之前的错误消息\\n→ 535:                     if (projectName || saveLocation) {\\n  536:                         hideError();\\n  537:                     }\\n  538: \\n\"},{\"line_number\":541,\"context\":\"  538: \\n  539:                     // 启用或禁用创建按钮\\n  540:                     if (createButton) {\\n→ 541:                         createButton.disabled = !projectName || !saveLocation;\\n  542:                         console.log('Create button disabled state:', createButton.disabled);\\n  543:                     }\\n  544:                 }\\n\"},{\"line_number\":550,\"context\":\"  547:                 function createProject() {\\n  548:                     console.log('Creating project...');\\n  549:                     const projectName = document.getElementById('projectName').value.trim();\\n→ 550:                     const saveLocation = document.getElementById('saveLocation').value.trim();\\n  551:                     const appId = document.getElementById('appId').value.trim();\\n  552:                     const resolution = document.getElementById('resolution').value;\\n  553:                     const minSdk = document.getElementById('minSdk').value;\\n\"},{\"line_number\":557,\"context\":\"  554:                     const pixelMode = document.getElementById('pixelMode').value;\\n  555:                     const honeyguiSdkPath = document.getElementById('honeyguiSdkPath').value.trim();\\n  556:                     \\n→ 557:                     console.log('Project config:', { projectName, saveLocation, appId, resolution, minSdk, pixelMode, honeyguiSdkPath });\\n  558:                     \\n  559:                     vscode.postMessage({\\n  560:                         command: 'createProject',\\n\"},{\"line_number\":563,\"context\":\"  560:                         command: 'createProject',\\n  561:                         config: {\\n  562:                             projectName,\\n→ 563:                             saveLocation,\\n  564:                             appId,\\n  565:                             resolution,\\n  566:                             minSdk,\\n\"},{\"line_number\":611,\"context\":\"  608: \\n  609:                     switch (message.command) {\\n  610:                         case 'folderSelected':\\n→ 611:                             document.getElementById('saveLocation').value = message.folderPath;\\n  612:                             hideError(); // 清除错误消息\\n  613:                             validateForm();\\n  614:                             break;\\n\"},{\"line_number\":697,\"context\":\"  694:      */\\n  695:     private async _createProject(config: any): Promise<void> {\\n  696:         try {\\n→ 697:             const { projectName, saveLocation, appId, resolution, minSdk, pixelMode, honeyguiSdkPath } = config;\\n  698: \\n  699:             // 记录日志用于调试\\n  700:             console.log(`[CreateProjectPanel] Creating project: projectName=${projectName}, saveLocation=${saveLocation}, appId=${appId}, sdkPath=${honeyguiSdkPath}`);\\n\"},{\"line_number\":700,\"context\":\"  697:             const { projectName, saveLocation, appId, resolution, minSdk, pixelMode, honeyguiSdkPath } = config;\\n  698: \\n  699:             // 记录日志用于调试\\n→ 700:             console.log(`[CreateProjectPanel] Creating project: projectName=${projectName}, saveLocation=${saveLocation}, appId=${appId}, sdkPath=${honeyguiSdkPath}`);\\n  701: \\n  702:             // 设置默认 SDK 路径\\n  703:             const sdkPath = honeyguiSdkPath || path.join(require('os').homedir()