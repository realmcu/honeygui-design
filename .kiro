                      "exit_status": "0",
                      "stdout": "/**\n * 调试日志工具\n * 通过环境变量控制是否输出日志\n */\n\nconst DEBUG = process.env.NODE_ENV === 'development';\n\nexport const logger = {\n  drop: (...args: any[]) => {\n    if (DEBUG) {\n      console.log('[拖放]', ...args);\n    }\n  },\n  \n  info: (...args: any[]) => {\n    if (DEBUG) {\n      console.info(...args);\n    }\n  },\n  \n  warn: (...args: any[]) => {\n    console.warn(...args);\n  },\n  \n  error: (...args: any[]) => {\n    console.error(...args);\n  },\n};",
                      "stderr": ""
